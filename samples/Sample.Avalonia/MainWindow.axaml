<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Sample.Avalonia.MainWindow"
        Title="CRDebugger Avalonia Sample" Width="600" Height="400">
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="CRDebugger Avalonia サンプル" FontSize="24" FontWeight="Bold"/>
        <TextBlock Text="下のボタンでデバッガーを開きます"/>
        <Button Content="CRDebugger を開く (F12)" Click="OnOpenDebugger" />
        <Button Content="ログを追加" Click="OnAddLog" />
        <Button Content="警告を追加" Click="OnAddWarning" />
        <Button Content="エラーを追加" Click="OnAddError" />
    </StackPanel>
</Window>
