<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- モダンダークテーマ -->
    <Color x:Key="BackgroundColor">#FF1A1A2E</Color>
    <Color x:Key="SurfaceColor">#FF232338</Color>
    <Color x:Key="SurfaceAltColor">#FF2D2D45</Color>
    <Color x:Key="PrimaryColor">#FF7C8FFF</Color>
    <Color x:Key="OnBackgroundColor">#FFC0C0D5</Color>
    <Color x:Key="OnSurfaceColor">#FFC0C0D5</Color>
    <Color x:Key="OnSurfaceMutedColor">#FF9090A5</Color>
    <Color x:Key="BorderColor">#FF3A3A55</Color>
    <Color x:Key="SidebarBackgroundColor">#FF12121C</Color>
    <Color x:Key="SidebarTextColor">#FF9090A5</Color>
    <Color x:Key="SelectedTabColor">#FF7C8FFF</Color>
    <Color x:Key="LogDebugColor">#FF6CAEDD</Color>
    <Color x:Key="LogInfoColor">#FF9090A5</Color>
    <Color x:Key="LogWarningColor">#FFE8C44A</Color>
    <Color x:Key="LogErrorColor">#FFE05252</Color>
    <Color x:Key="SuccessColor">#FF4CAF50</Color>
    <Color x:Key="HeaderCRColor">#FF7C8FFF</Color>
    <Color x:Key="HeaderDebuggerColor">#FF606080</Color>
    <Color x:Key="MutedTextColor">#FF606075</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="OnBackgroundBrush" Color="{StaticResource OnBackgroundColor}" />
    <SolidColorBrush x:Key="OnSurfaceBrush" Color="{StaticResource OnSurfaceColor}" />
    <SolidColorBrush x:Key="OnSurfaceMutedBrush" Color="{StaticResource OnSurfaceMutedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}" />
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{StaticResource SidebarTextColor}" />
    <SolidColorBrush x:Key="SelectedTabBrush" Color="{StaticResource SelectedTabColor}" />
    <SolidColorBrush x:Key="LogDebugBrush" Color="{StaticResource LogDebugColor}" />
    <SolidColorBrush x:Key="LogInfoBrush" Color="{StaticResource LogInfoColor}" />
    <SolidColorBrush x:Key="LogWarningBrush" Color="{StaticResource LogWarningColor}" />
    <SolidColorBrush x:Key="LogErrorBrush" Color="{StaticResource LogErrorColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="HeaderCRBrush" Color="{StaticResource HeaderCRColor}" />
    <SolidColorBrush x:Key="HeaderDebuggerBrush" Color="{StaticResource HeaderDebuggerColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />

    <!-- ScrollBar スタイル -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="6" />
    </Style>

    <!-- TextBox スタイル -->
    <Style x:Key="CRTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="CaretBrush" Value="{StaticResource OnSurfaceBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource PrimaryBrush}" />
    </Style>

    <!-- Button スタイル -->
    <Style x:Key="CRButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="18,9" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.88" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.7" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ToggleButton（フィルター用） -->
    <Style x:Key="CRFilterToggle" TargetType="ToggleButton">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceMutedBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="White" />
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource PrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.88" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- サイドバーボタン（アクティブタブインジケーター付き） -->
    <Style x:Key="SidebarButton" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <!-- アクティブタブインジケーター（左端の3pxアクセントバー） -->
                        <Border x:Name="ActiveIndicator"
                                HorizontalAlignment="Left"
                                Width="3"
                                CornerRadius="0,2,2,0"
                                Background="Transparent"
                                Margin="0,4,0,4" />
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                Margin="3,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="Icon"
                                           Text="{TemplateBinding Tag}"
                                           FontSize="16"
                                           Width="24"
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center" />
                                <ContentPresenter VerticalAlignment="Center"
                                                  Margin="6,0,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="#1A7C8FFF" />
                            <Setter Property="Foreground"
                                    Value="{StaticResource SelectedTabBrush}" />
                            <Setter TargetName="ActiveIndicator" Property="Background"
                                    Value="{StaticResource SelectedTabBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="#0D7C8FFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CheckBox スタイル -->
    <Style x:Key="CRCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- ComboBox スタイル -->
    <Style x:Key="CRComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="Padding" Value="10,8" />
    </Style>

    <!-- Slider スタイル -->
    <Style x:Key="CRSlider" TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
    </Style>

</ResourceDictionary>
