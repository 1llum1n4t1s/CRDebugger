<UserControl x:Class="CRDebugger.Wpf.Views.SystemInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CRDebugger.Core.ViewModels">

    <DockPanel Margin="20">
        <!-- ヘッダー -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="System Information"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource OnBackgroundBrush}"
                       VerticalAlignment="Center" />
            <Button Content="Refresh"
                    Style="{DynamicResource CRButton}"
                    Command="{Binding RefreshCommand}"
                    HorizontalAlignment="Right"
                    Padding="14,7" />
        </DockPanel>

        <!-- システム情報リスト -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:SystemInfoGroup}">
                        <Border Background="{DynamicResource SurfaceBrush}"
                                CornerRadius="8"
                                Margin="0,0,0,14"
                                Padding="18,14">
                            <!-- カテゴリヘッダー -->
                            <StackPanel>
                                <TextBlock Text="{Binding Category}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           Margin="0,0,0,10" />

                                <!-- キーバリュー一覧 -->
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:SystemInfoItem}">
                                            <DockPanel Margin="0,4,0,4">
                                                <TextBlock Text="{Binding Key}"
                                                           Foreground="{DynamicResource OnSurfaceMutedBrush}"
                                                           FontSize="12"
                                                           Width="200"
                                                           DockPanel.Dock="Left" />
                                                <TextBlock Text="{Binding Value}"
                                                           Foreground="{DynamicResource OnSurfaceBrush}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
