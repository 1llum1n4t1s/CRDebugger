<UserControl x:Class="CRDebugger.Wpf.Views.BugReporterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <DockPanel Margin="16">
        <!-- ヘッダー -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Bug Reporter"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{DynamicResource OnBackgroundBrush}"
                   Margin="0,0,0,12" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="600"
                        HorizontalAlignment="Left">
                <!-- バグレポートフォーム -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="6"
                        Padding="20,16"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Describe the issue"
                                   Foreground="{DynamicResource OnSurfaceBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <!-- メッセージ入力 -->
                        <TextBox Style="{DynamicResource CRTextBox}"
                                 Text="{Binding UserMessage, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="120"
                                 MaxHeight="200"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,16" />

                        <!-- メールアドレス -->
                        <TextBlock Text="Your email (optional)"
                                   Foreground="{DynamicResource OnSurfaceBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <TextBox Style="{DynamicResource CRTextBox}"
                                 Text="{Binding UserEmail, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,16" />

                        <!-- 送信ボタン -->
                        <DockPanel>
                            <Button Content="Send Bug Report"
                                    Style="{DynamicResource CRButton}"
                                    Command="{Binding SendCommand}"
                                    IsEnabled="{Binding IsSending, Converter={StaticResource InverseBoolConverter}}"
                                    DockPanel.Dock="Left" />

                            <!-- 送信中インジケーター -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsSending, Converter={StaticResource BoolToVis}}"
                                        VerticalAlignment="Center"
                                        Margin="12,0,0,0">
                                <TextBlock Text="Sending..."
                                           Foreground="{DynamicResource OnSurfaceMutedBrush}"
                                           FontSize="12" />
                            </StackPanel>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- ステータスメッセージ -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="6"
                        Padding="16,12"
                        Visibility="{Binding StatusMessage, Converter={StaticResource NullOrEmptyToCollapsedConverter}}">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource OnSurfaceBrush}"
                               FontSize="13"
                               TextWrapping="Wrap" />
                </Border>

                <!-- 情報テキスト -->
                <TextBlock Margin="0,16,0,0"
                           Foreground="{DynamicResource OnSurfaceMutedBrush}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Text="Bug reports include system information, recent console logs, and an optional screenshot. This data helps developers diagnose and fix issues." />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
