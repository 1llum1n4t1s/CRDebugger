<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net6.0-windows;net8.0-windows</TargetFrameworks>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>12</LangVersion>
    <RootNamespace>CRDebugger.Wpf</RootNamespace>
    <IsPackable>true</IsPackable>
    <PackageId>CRDebugger.Wpf</PackageId>
    <Version>1.0.0</Version>
    <Authors>ゆろち</Authors>
    <Description>CRDebugger WPF UI - SRDebugger-like debug panel for WPF apps</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\CRDebugger.Core\CRDebugger.Core.csproj" />
  </ItemGroup>
</Project>
