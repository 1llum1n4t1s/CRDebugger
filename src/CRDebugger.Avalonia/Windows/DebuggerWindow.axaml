<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CRDebugger.Core.ViewModels"
        xmlns:core="using:CRDebugger.Core"
        xmlns:conv="using:CRDebugger.Avalonia.Converters"
        xmlns:views="using:CRDebugger.Avalonia.Views"
        x:Class="CRDebugger.Avalonia.Windows.DebuggerWindow"
        x:DataType="vm:DebuggerViewModel"
        x:Name="root"
        Title="CRDEBUGGER"
        Width="900" Height="600"
        MinWidth="600" MinHeight="400"
        Topmost="False"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        SystemDecorations="Full"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

  <Window.Resources>
    <conv:TabEqualsConverter x:Key="TabEquals"/>
    <conv:CountToVisibilityConverter x:Key="CountToVis"/>
  </Window.Resources>

  <Window.Styles>
    <!-- ═══════════════════════════════════ -->
    <!-- サイドバーボタン - モダンスタイル -->
    <!-- ═══════════════════════════════════ -->
    <Style Selector="Button.sidebar-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#9090A5"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Foreground" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.sidebar-btn /template/ ContentPresenter">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.sidebar-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#FFFFFF08"/>
    </Style>
    <Style Selector="Button.sidebar-btn:pointerover">
      <Setter Property="Foreground" Value="#C0C0D0"/>
    </Style>
    <Style Selector="Button.sidebar-btn.active /template/ ContentPresenter">
      <Setter Property="Background" Value="#FFFFFF0C"/>
    </Style>
    <Style Selector="Button.sidebar-btn.active">
      <Setter Property="Foreground" Value="#7C8FFF"/>
    </Style>

    <!-- アクティブインジケーター（左端の縦バー） -->
    <Style Selector="Button.sidebar-btn Border.active-indicator">
      <Setter Property="Width" Value="3"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="CornerRadius" Value="0,2,2,0"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.2"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.sidebar-btn.active Border.active-indicator">
      <Setter Property="Background" Value="#7C8FFF"/>
    </Style>

    <!-- バッジ - モダン -->
    <Style Selector="Border.badge">
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="6,2"/>
      <Setter Property="MinWidth" Value="22"/>
      <Setter Property="HorizontalAlignment" Value="Right"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- コンテンツエリア共通 - 薄いボーダー -->
    <Style Selector="Border.content-area">
      <Setter Property="Background" Value="#1A1A2E"/>
      <Setter Property="CornerRadius" Value="12,0,0,0"/>
    </Style>
  </Window.Styles>

  <!-- ルートパネル（アクリル背景） -->
  <Panel>
    <!-- アクリル背景レイヤー -->
    <ExperimentalAcrylicBorder IsHitTestVisible="False">
      <ExperimentalAcrylicBorder.Material>
        <ExperimentalAcrylicMaterial
          BackgroundSource="Digger"
          TintColor="#12121C"
          TintOpacity="0.92"
          MaterialOpacity="0.4"/>
      </ExperimentalAcrylicBorder.Material>
    </ExperimentalAcrylicBorder>

    <Grid ColumnDefinitions="170,*">
      <!-- ═══════════════════════════════════ -->
      <!-- 左サイドバー（アクリル半透明） -->
      <!-- ═══════════════════════════════════ -->
      <Panel Grid.Column="0">
        <!-- サイドバーアクリル背景 -->
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
          <ExperimentalAcrylicBorder.Material>
            <ExperimentalAcrylicMaterial
              BackgroundSource="Digger"
              TintColor="#0E0E18"
              TintOpacity="0.88"
              MaterialOpacity="0.3"/>
          </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <DockPanel>
          <!-- ブランディングヘッダー -->
          <Border DockPanel.Dock="Top" Padding="16,14"
                  BorderBrush="#FFFFFF08" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
              <TextBlock Text="CR" FontWeight="Bold" FontSize="17" Foreground="#7C8FFF"
                         LetterSpacing="1"/>
              <TextBlock Text="DEBUGGER" FontWeight="SemiBold" FontSize="17" Foreground="#606080"
                         LetterSpacing="1"/>
            </StackPanel>
          </Border>

          <!-- タブボタン群 -->
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,8">
              <!-- System タブ -->
              <Button Classes="sidebar-btn"
                      Classes.active="{Binding SelectedTab, Converter={StaticResource TabEquals}, ConverterParameter=System}"
                      Click="OnTabClick" Tag="{x:Static core:CRTab.System}">
                <Grid ColumnDefinitions="3,*">
                  <Border Grid.Column="0" Classes="active-indicator"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" Margin="14,13">
                    <TextBlock Text="&#x2699;" FontSize="16" VerticalAlignment="Center" Opacity="0.8"/>
                    <TextBlock Text="System" VerticalAlignment="Center" FontWeight="Medium"/>
                  </StackPanel>
                </Grid>
              </Button>

              <!-- Console タブ -->
              <Button Classes="sidebar-btn"
                      Classes.active="{Binding SelectedTab, Converter={StaticResource TabEquals}, ConverterParameter=Console}"
                      Click="OnTabClick" Tag="{x:Static core:CRTab.Console}">
                <Grid ColumnDefinitions="3,*">
                  <Border Grid.Column="0" Classes="active-indicator"/>
                  <Grid Grid.Column="1" Margin="14,13">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                      <TextBlock Text="&#x25B6;" FontSize="14" VerticalAlignment="Center" Opacity="0.8"/>
                      <TextBlock Text="Console" VerticalAlignment="Center" FontWeight="Medium"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4" VerticalAlignment="Center">
                      <Border Classes="badge" Background="#E05252"
                              IsVisible="{Binding Console.ErrorCount, Converter={StaticResource CountToVis}}">
                        <TextBlock Text="{Binding Console.ErrorCount}" Foreground="White" FontSize="10"
                                   HorizontalAlignment="Center" FontWeight="Bold"/>
                      </Border>
                      <Border Classes="badge" Background="#E8C44A"
                              IsVisible="{Binding Console.WarningCount, Converter={StaticResource CountToVis}}">
                        <TextBlock Text="{Binding Console.WarningCount}" Foreground="#1A1A2E" FontSize="10"
                                   HorizontalAlignment="Center" FontWeight="Bold"/>
                      </Border>
                    </StackPanel>
                  </Grid>
                </Grid>
              </Button>

              <!-- Options タブ -->
              <Button Classes="sidebar-btn"
                      Classes.active="{Binding SelectedTab, Converter={StaticResource TabEquals}, ConverterParameter=Options}"
                      Click="OnTabClick" Tag="{x:Static core:CRTab.Options}">
                <Grid ColumnDefinitions="3,*">
                  <Border Grid.Column="0" Classes="active-indicator"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" Margin="14,13">
                    <TextBlock Text="&#x2630;" FontSize="16" VerticalAlignment="Center" Opacity="0.8"/>
                    <TextBlock Text="Options" VerticalAlignment="Center" FontWeight="Medium"/>
                  </StackPanel>
                </Grid>
              </Button>

              <!-- Profiler タブ -->
              <Button Classes="sidebar-btn"
                      Classes.active="{Binding SelectedTab, Converter={StaticResource TabEquals}, ConverterParameter=Profiler}"
                      Click="OnTabClick" Tag="{x:Static core:CRTab.Profiler}">
                <Grid ColumnDefinitions="3,*">
                  <Border Grid.Column="0" Classes="active-indicator"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" Margin="14,13">
                    <TextBlock Text="&#x26A1;" FontSize="16" VerticalAlignment="Center" Opacity="0.8"/>
                    <TextBlock Text="Profiler" VerticalAlignment="Center" FontWeight="Medium"/>
                  </StackPanel>
                </Grid>
              </Button>

              <!-- Bug Reporter タブ -->
              <Button Classes="sidebar-btn"
                      Classes.active="{Binding SelectedTab, Converter={StaticResource TabEquals}, ConverterParameter=BugReporter}"
                      Click="OnTabClick" Tag="{x:Static core:CRTab.BugReporter}">
                <Grid ColumnDefinitions="3,*">
                  <Border Grid.Column="0" Classes="active-indicator"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" Margin="14,13">
                    <TextBlock Text="&#x1F41E;" FontSize="16" VerticalAlignment="Center" Opacity="0.8"/>
                    <TextBlock Text="Bug Report" VerticalAlignment="Center" FontWeight="Medium"/>
                  </StackPanel>
                </Grid>
              </Button>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>

        <!-- サイドバー右端の薄いボーダー -->
        <Border HorizontalAlignment="Right" Width="1" Background="#FFFFFF08"/>
      </Panel>

      <!-- ═══════════════════════════════════ -->
      <!-- 右コンテンツエリア -->
      <!-- ═══════════════════════════════════ -->
      <Border Grid.Column="1" Classes="content-area">
        <Panel>
          <!-- ピン + 閉じるボタン（コンテンツエリア右上） -->
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                      Spacing="2" Margin="0,6,8,0" ZIndex="100">
            <Button x:Name="PinButton"
                    Click="OnPinClick"
                    Background="Transparent" BorderThickness="0"
                    Padding="4" Cursor="Hand" ToolTip.Tip="常に前面に固定"
                    Width="30" Height="30">
              <TextBlock x:Name="PinIcon" Text="📌" FontSize="13" Opacity="0.4"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
            <Button Click="OnCloseClick"
                    Background="Transparent" BorderThickness="0"
                    Padding="4" Cursor="Hand" ToolTip.Tip="閉じる"
                    Width="30" Height="30">
              <TextBlock Text="✕" Foreground="#808095" FontSize="15"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
          </StackPanel>
          <views:SystemInfoView DataContext="{Binding SystemInfo}"
                                IsVisible="{Binding #root.((vm:DebuggerViewModel)DataContext).SelectedTab, Converter={StaticResource TabEquals}, ConverterParameter=System}"/>
          <views:ConsoleView DataContext="{Binding Console}"
                             IsVisible="{Binding #root.((vm:DebuggerViewModel)DataContext).SelectedTab, Converter={StaticResource TabEquals}, ConverterParameter=Console}"/>
          <views:OptionsView DataContext="{Binding Options}"
                             IsVisible="{Binding #root.((vm:DebuggerViewModel)DataContext).SelectedTab, Converter={StaticResource TabEquals}, ConverterParameter=Options}"/>
          <views:ProfilerView DataContext="{Binding Profiler}"
                              IsVisible="{Binding #root.((vm:DebuggerViewModel)DataContext).SelectedTab, Converter={StaticResource TabEquals}, ConverterParameter=Profiler}"/>
          <views:BugReporterView DataContext="{Binding BugReporter}"
                                 IsVisible="{Binding #root.((vm:DebuggerViewModel)DataContext).SelectedTab, Converter={StaticResource TabEquals}, ConverterParameter=BugReporter}"/>
        </Panel>
      </Border>
    </Grid>
  </Panel>
</Window>
