<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CRDebugger.Core.ViewModels"
             x:Class="CRDebugger.Avalonia.Views.SystemInfoView"
             x:DataType="vm:SystemInfoViewModel">

  <UserControl.Styles>
    <Style Selector="TextBlock.header">
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="#C0C0D5"/>
      <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>
    <Style Selector="TextBlock.category-name">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#7C8FFF"/>
      <Setter Property="Margin" Value="0,12,0,8"/>
    </Style>
    <Style Selector="TextBlock.info-key">
      <Setter Property="Foreground" Value="#9090A5"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="MinWidth" Value="180"/>
    </Style>
    <Style Selector="TextBlock.info-value">
      <Setter Property="Foreground" Value="#C0C0D5"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <!-- Refreshボタン -->
    <Style Selector="Button.refresh-btn">
      <Setter Property="Background" Value="#FFFFFF08"/>
      <Setter Property="Foreground" Value="#C0C0D5"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#FFFFFF08"/>
      <Setter Property="Padding" Value="18,7"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.refresh-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#FFFFFF10"/>
    </Style>
    <!-- カテゴリカード -->
    <Style Selector="Border.category-card">
      <Setter Property="Background" Value="#FFFFFF06"/>
      <Setter Property="BorderBrush" Value="#FFFFFF08"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14,10"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.category-card:pointerover">
      <Setter Property="Background" Value="#FFFFFF0A"/>
    </Style>
  </UserControl.Styles>

  <DockPanel Margin="20">
    <!-- ヘッダー -->
    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
      <TextBlock Text="System Information" Classes="header" DockPanel.Dock="Left"/>
      <Button Content="Refresh" Command="{Binding RefreshCommand}"
              Classes="refresh-btn"
              HorizontalAlignment="Right"/>
    </DockPanel>

    <!-- システム情報リスト -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding Groups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:SystemInfoGroup">
            <StackPanel Margin="0,0,0,8">
              <!-- カテゴリ名 -->
              <TextBlock Text="{Binding Category}" Classes="category-name"/>
              <Border Classes="category-card">
                <ItemsControl ItemsSource="{Binding Items}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SystemInfoItem">
                      <Grid ColumnDefinitions="180,*" Margin="0,4">
                        <TextBlock Grid.Column="0" Text="{Binding Key}" Classes="info-key"/>
                        <TextBlock Grid.Column="1" Text="{Binding Value}" Classes="info-value"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Border>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>
