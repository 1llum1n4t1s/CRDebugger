<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CRDebugger.Core.ViewModels"
             xmlns:conv="using:CRDebugger.Avalonia.Converters"
             x:Class="CRDebugger.Avalonia.Views.OptionsView"
             x:DataType="vm:OptionsViewModel">

  <UserControl.Resources>
    <conv:OptionKindEqualsConverter x:Key="KindEquals"/>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="TextBlock.header">
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="#C0C0D5"/>
      <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>
    <Style Selector="TextBlock.category-header">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#7C8FFF"/>
      <Setter Property="Margin" Value="0,12,0,8"/>
    </Style>
    <Style Selector="TextBlock.option-label">
      <Setter Property="Foreground" Value="#C0C0D5"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <!-- Refreshボタン -->
    <Style Selector="Button.refresh-btn">
      <Setter Property="Background" Value="#FFFFFF08"/>
      <Setter Property="Foreground" Value="#C0C0D5"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#FFFFFF08"/>
      <Setter Property="Padding" Value="18,7"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.refresh-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#FFFFFF10"/>
    </Style>
    <!-- カテゴリカード -->
    <Style Selector="Border.option-card">
      <Setter Property="Background" Value="#FFFFFF06"/>
      <Setter Property="BorderBrush" Value="#FFFFFF08"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14,10"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.option-card:pointerover">
      <Setter Property="Background" Value="#FFFFFF0A"/>
    </Style>
    <!-- アクションボタン -->
    <Style Selector="Button.action-btn">
      <Setter Property="Background" Value="#FFFFFF08"/>
      <Setter Property="Foreground" Value="#C0C0D5"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#FFFFFF10"/>
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="Margin" Value="0,3"/>
    </Style>
    <Style Selector="Button.action-btn /template/ ContentPresenter">
      <Setter Property="Background" Value="#FFFFFF08"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.action-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#FFFFFF14"/>
    </Style>
  </UserControl.Styles>

  <DockPanel Margin="20">
    <!-- ヘッダー -->
    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
      <TextBlock Text="Options" Classes="header" DockPanel.Dock="Left"/>
      <Button Content="Refresh" Command="{Binding RefreshCommand}"
              Classes="refresh-btn"
              HorizontalAlignment="Right"/>
    </DockPanel>

    <!-- オプションカテゴリリスト -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding Categories}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:OptionCategoryViewModel">
            <StackPanel Margin="0,0,0,8">
              <TextBlock Text="{Binding Name}" Classes="category-header"/>
              <!-- アクションボタン群 -->
              <ItemsControl ItemsSource="{Binding Actions}" Margin="0,0,0,4">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ActionItemViewModel">
                    <Button Content="{Binding Label}"
                            Command="{Binding ExecuteCommand}"
                            Classes="action-btn"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <!-- オプション（Items が空なら非表示） -->
              <Border Classes="option-card"
                      IsVisible="{Binding Items.Count}">
                <ItemsControl ItemsSource="{Binding Items}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:OptionItemViewModel">
                      <Panel>
                        <!-- オプション表示 (Action以外のKindのみ表示) -->
                        <Grid ColumnDefinitions="200,*" Margin="0,6" MinHeight="28">
                          <TextBlock Grid.Column="0" Text="{Binding DisplayName}" Classes="option-label"/>

                          <Panel Grid.Column="1">
                            <!-- Boolean: ToggleSwitch -->
                            <ToggleSwitch IsChecked="{Binding Value}"
                                          IsEnabled="{Binding IsReadOnly, Converter={x:Static conv:InverseBoolConverter.Instance}}"
                                          IsVisible="{Binding Kind, Converter={StaticResource KindEquals}, ConverterParameter=Boolean}"
                                          OnContent="ON" OffContent="OFF"/>

                            <!-- Integer: NumericUpDown -->
                            <NumericUpDown Value="{Binding Value}"
                                           Minimum="{Binding Min}" Maximum="{Binding Max}"
                                           Increment="{Binding Step}"
                                           IsReadOnly="{Binding IsReadOnly}"
                                           IsVisible="{Binding Kind, Converter={StaticResource KindEquals}, ConverterParameter=Integer}"
                                           Background="#FFFFFF06" Foreground="#C0C0D5"
                                           BorderBrush="#FFFFFF08" Width="160" FontSize="12"/>

                            <!-- Float: NumericUpDown (decimal) -->
                            <NumericUpDown Value="{Binding Value}"
                                           Minimum="{Binding Min}" Maximum="{Binding Max}"
                                           Increment="{Binding Step}"
                                           IsReadOnly="{Binding IsReadOnly}"
                                           IsVisible="{Binding Kind, Converter={StaticResource KindEquals}, ConverterParameter=Float}"
                                           Background="#FFFFFF06" Foreground="#C0C0D5"
                                           BorderBrush="#FFFFFF08" Width="160" FontSize="12"
                                           FormatString="F2"/>

                            <!-- String: TextBox -->
                            <TextBox Text="{Binding Value}"
                                     IsReadOnly="{Binding IsReadOnly}"
                                     IsVisible="{Binding Kind, Converter={StaticResource KindEquals}, ConverterParameter=String}"
                                     Background="#FFFFFF06" Foreground="#C0C0D5"
                                     BorderBrush="#FFFFFF08" MaxWidth="300" FontSize="12"
                                     CornerRadius="8" Padding="10,6"/>

                            <!-- Enum: ComboBox -->
                            <ComboBox ItemsSource="{Binding EnumNames}"
                                      SelectedItem="{Binding Value}"
                                      IsVisible="{Binding Kind, Converter={StaticResource KindEquals}, ConverterParameter=Enum}"
                                      Background="#FFFFFF06" Foreground="#C0C0D5"
                                      BorderBrush="#FFFFFF08" MaxWidth="200" FontSize="12"/>

                            <!-- ReadOnly: 表示のみ -->
                            <TextBlock Text="{Binding Value}"
                                       IsVisible="{Binding Kind, Converter={StaticResource KindEquals}, ConverterParameter=ReadOnly}"
                                       Foreground="#606075" FontSize="12"
                                       VerticalAlignment="Center"/>
                          </Panel>
                        </Grid>
                      </Panel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Border>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>
