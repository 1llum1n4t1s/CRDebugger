<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CRDebugger.Core.ViewModels"
             x:Class="CRDebugger.Avalonia.Views.ProfilerView"
             x:DataType="vm:ProfilerViewModel">

  <UserControl.Styles>
    <StyleInclude Source="avares://CRDebugger.Avalonia/Styles/SharedStyles.axaml"/>
    <!-- メトリクスラベル（Profiler固有） -->
    <Style Selector="TextBlock.metric-label">
      <Setter Property="Foreground" Value="{DynamicResource CRTextSecondaryBrush}"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="TextBlock.metric-value">
      <Setter Property="Foreground" Value="{DynamicResource CRTextPrimaryBrush}"/>
      <Setter Property="FontSize" Value="24"/>
      <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style Selector="TextBlock.metric-unit">
      <Setter Property="Foreground" Value="{DynamicResource CRTextMutedBrush}"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <!-- GC Collectボタン（Profiler固有） -->
    <Style Selector="Button.gc-btn">
      <Setter Property="Background" Value="#E0525220"/>
      <Setter Property="Foreground" Value="#E05252"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#E0525230"/>
      <Setter Property="Padding" Value="18,7"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.gc-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#E0525235"/>
    </Style>
  </UserControl.Styles>

  <DockPanel Margin="20">
    <!-- ヘッダー -->
    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
      <TextBlock Text="Profiler" Classes="header" DockPanel.Dock="Left"/>
      <Button Content="GC Collect" Command="{Binding GcCollectCommand}"
              Classes="gc-btn"
              HorizontalAlignment="Right"/>
    </DockPanel>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="0">
        <!-- メモリメトリクスカード群 -->
        <TextBlock Text="Memory" Classes="category-header"/>
        <UniformGrid Columns="3" Margin="0,0,0,0">
          <!-- Working Set -->
          <Border Classes="cr-card" Margin="0,0,8,8">
            <StackPanel>
              <TextBlock Text="Working Set" Classes="metric-label"/>
              <TextBlock Text="{Binding WorkingSet}" Classes="metric-value"/>
            </StackPanel>
          </Border>
          <!-- Private Memory -->
          <Border Classes="cr-card" Margin="4,0,4,8">
            <StackPanel>
              <TextBlock Text="Private Memory" Classes="metric-label"/>
              <TextBlock Text="{Binding PrivateMemory}" Classes="metric-value"/>
            </StackPanel>
          </Border>
          <!-- GC Memory -->
          <Border Classes="cr-card" Margin="8,0,0,8">
            <StackPanel>
              <TextBlock Text="GC Memory" Classes="metric-label"/>
              <TextBlock Text="{Binding GcMemory}" Classes="metric-value"/>
            </StackPanel>
          </Border>
        </UniformGrid>

        <!-- GC コレクション統計 -->
        <TextBlock Text="GC Collections" Classes="category-header"/>
        <UniformGrid Columns="3" Margin="0,0,0,0">
          <Border Classes="cr-card" Margin="0,0,8,8">
            <StackPanel>
              <TextBlock Text="Gen 0" Classes="metric-label"/>
              <TextBlock Text="{Binding Gen0}" Classes="metric-value" Foreground="#4CAF50"/>
            </StackPanel>
          </Border>
          <Border Classes="cr-card" Margin="4,0,4,8">
            <StackPanel>
              <TextBlock Text="Gen 1" Classes="metric-label"/>
              <TextBlock Text="{Binding Gen1}" Classes="metric-value" Foreground="#E8C44A"/>
            </StackPanel>
          </Border>
          <Border Classes="cr-card" Margin="8,0,0,8">
            <StackPanel>
              <TextBlock Text="Gen 2" Classes="metric-label"/>
              <TextBlock Text="{Binding Gen2}" Classes="metric-value" Foreground="#E05252"/>
            </StackPanel>
          </Border>
        </UniformGrid>

        <!-- FPS -->
        <TextBlock Text="Performance" Classes="category-header"/>
        <UniformGrid Columns="2" Margin="0,0,0,0">
          <Border Classes="cr-card" Margin="0,0,8,8">
            <StackPanel>
              <TextBlock Text="FPS (estimated)" Classes="metric-label"/>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{Binding Fps, StringFormat='{}{0:F1}'}" Classes="metric-value" Foreground="#7C8FFF"/>
                <TextBlock Text="fps" Classes="metric-unit" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
              </StackPanel>
            </StackPanel>
          </Border>
          <!-- CPU使用率カード -->
          <Border Classes="cr-card" Margin="8,0,0,8">
            <StackPanel>
              <TextBlock Text="CPU Usage" Classes="metric-label"/>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{Binding CpuUsageDisplay}" Classes="metric-value" Foreground="#FF9800"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </UniformGrid>

        <!-- CPUホットスポット -->
        <TextBlock Text="CPU Hotspots" Classes="category-header"/>
        <Border Classes="cr-card">
          <StackPanel>
            <!-- ホットスポットが無い場合のプレースホルダー -->
            <TextBlock Text="CRDebugger.Measure() で計測を開始してください"
                       IsVisible="{Binding !HasHotspots}"
                       Foreground="{DynamicResource CRTextMutedBrush}"
                       FontSize="12"
                       FontStyle="Italic"
                       Margin="0,4"/>

            <!-- ホットスポットヘッダー行 -->
            <Grid IsVisible="{Binding HasHotspots}" Margin="0,0,0,6">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="100"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="操作名" Classes="metric-label" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="1" Text="呼出回数" Classes="metric-label" FontWeight="SemiBold" TextAlignment="Right"/>
              <TextBlock Grid.Column="2" Text="合計CPU" Classes="metric-label" FontWeight="SemiBold" TextAlignment="Right"/>
              <TextBlock Grid.Column="3" Text="割合" Classes="metric-label" FontWeight="SemiBold" Margin="8,0,0,0"/>
            </Grid>

            <!-- ホットスポットリスト -->
            <ItemsControl ItemsSource="{Binding CpuHotspots}" IsVisible="{Binding HasHotspots}">
              <ItemsControl.DataTemplates>
                <DataTemplate x:DataType="vm:HotspotItem">
                  <Border Padding="0,4" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource CRBorderBrush}">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="100"/>
                      </Grid.ColumnDefinitions>
                      <!-- 操作名とカテゴリ -->
                      <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding OperationName}"
                                   Foreground="{DynamicResource CRTextPrimaryBrush}"
                                   FontSize="12" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Category}"
                                   Foreground="{DynamicResource CRTextMutedBrush}"
                                   FontSize="10"/>
                      </StackPanel>
                      <!-- 呼出回数 -->
                      <TextBlock Grid.Column="1"
                                 Text="{Binding InvocationCount}"
                                 Foreground="{DynamicResource CRTextSecondaryBrush}"
                                 FontSize="12" TextAlignment="Right"
                                 VerticalAlignment="Center"/>
                      <!-- 合計CPU時間 -->
                      <TextBlock Grid.Column="2"
                                 Text="{Binding TotalCpuTime}"
                                 Foreground="{DynamicResource CRTextSecondaryBrush}"
                                 FontSize="12" TextAlignment="Right"
                                 VerticalAlignment="Center"/>
                      <!-- 割合バー -->
                      <Grid Grid.Column="3" VerticalAlignment="Center" Margin="8,0,0,0">
                        <Border Background="#333333" CornerRadius="3" Height="6"/>
                        <Border Background="#FF9800" CornerRadius="3" Height="6"
                                HorizontalAlignment="Left"
                                Width="{Binding CpuPercent}"/>
                      </Grid>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.DataTemplates>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- メモリホットスポット -->
        <TextBlock Text="Memory Hotspots" Classes="category-header" Margin="0,12,0,0"/>
        <Border Classes="cr-card">
          <StackPanel>
            <!-- メモリホットスポットが無い場合のプレースホルダー -->
            <TextBlock Text="CRDebugger.Measure() で計測を開始してください"
                       IsVisible="{Binding !HasMemoryHotspots}"
                       Foreground="{DynamicResource CRTextMutedBrush}"
                       FontSize="12"
                       FontStyle="Italic"
                       Margin="0,4"/>

            <!-- メモリホットスポットヘッダー行 -->
            <Grid IsVisible="{Binding HasMemoryHotspots}" Margin="0,0,0,6">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="100"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="操作名" Classes="metric-label" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="1" Text="呼出回数" Classes="metric-label" FontWeight="SemiBold" TextAlignment="Right"/>
              <TextBlock Grid.Column="2" Text="合計メモリ" Classes="metric-label" FontWeight="SemiBold" TextAlignment="Right"/>
              <TextBlock Grid.Column="3" Text="最大メモリ" Classes="metric-label" FontWeight="SemiBold" TextAlignment="Right"/>
              <TextBlock Grid.Column="4" Text="割合" Classes="metric-label" FontWeight="SemiBold" Margin="8,0,0,0"/>
            </Grid>

            <!-- メモリホットスポットリスト -->
            <ItemsControl ItemsSource="{Binding MemoryHotspots}" IsVisible="{Binding HasMemoryHotspots}">
              <ItemsControl.DataTemplates>
                <DataTemplate x:DataType="vm:MemoryHotspotItem">
                  <Border Padding="0,4" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource CRBorderBrush}">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="100"/>
                      </Grid.ColumnDefinitions>
                      <!-- 操作名とカテゴリ -->
                      <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding OperationName}"
                                   Foreground="{DynamicResource CRTextPrimaryBrush}"
                                   FontSize="12" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Category}"
                                   Foreground="{DynamicResource CRTextMutedBrush}"
                                   FontSize="10"/>
                      </StackPanel>
                      <!-- 呼出回数 -->
                      <TextBlock Grid.Column="1"
                                 Text="{Binding InvocationCount}"
                                 Foreground="{DynamicResource CRTextSecondaryBrush}"
                                 FontSize="12" TextAlignment="Right"
                                 VerticalAlignment="Center"/>
                      <!-- 合計メモリ -->
                      <TextBlock Grid.Column="2"
                                 Text="{Binding TotalMemoryDelta}"
                                 Foreground="{DynamicResource CRTextSecondaryBrush}"
                                 FontSize="12" TextAlignment="Right"
                                 VerticalAlignment="Center"/>
                      <!-- 最大メモリ -->
                      <TextBlock Grid.Column="3"
                                 Text="{Binding MaxMemoryDelta}"
                                 Foreground="{DynamicResource CRTextSecondaryBrush}"
                                 FontSize="12" TextAlignment="Right"
                                 VerticalAlignment="Center"/>
                      <!-- 割合バー -->
                      <Grid Grid.Column="4" VerticalAlignment="Center" Margin="8,0,0,0">
                        <Border Background="#333333" CornerRadius="3" Height="6"/>
                        <Border Background="#4CAF50" CornerRadius="3" Height="6"
                                HorizontalAlignment="Left"
                                Width="{Binding MemoryPercent}"/>
                      </Grid>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.DataTemplates>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</UserControl>
