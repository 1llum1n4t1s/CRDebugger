<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CRDebugger.Core.ViewModels"
             xmlns:log="using:CRDebugger.Core.Logging"
             xmlns:conv="using:CRDebugger.Avalonia.Converters"
             x:Class="CRDebugger.Avalonia.Views.ConsoleView"
             x:DataType="vm:ConsoleViewModel">

  <UserControl.Resources>
    <conv:LogLevelToBrushConverter x:Key="LevelToBrush"/>
    <conv:LogLevelToStringConverter x:Key="LevelToStr"/>
    <conv:TimestampConverter x:Key="Timestamp"/>
    <conv:NotNullOrEmptyConverter x:Key="NotNullOrEmpty"/>
    <conv:InverseBoolConverter x:Key="InverseBool"/>
  </UserControl.Resources>

  <UserControl.Styles>
    <StyleInclude Source="avares://CRDebugger.Avalonia/Styles/SharedStyles.axaml"/>
    <!-- フィルタートグルボタン - モダン -->
    <Style Selector="ToggleButton.filter-btn">
      <Setter Property="Background" Value="#FFFFFF06"/>
      <Setter Property="Foreground" Value="#707085"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#FFFFFF08"/>
      <Setter Property="Padding" Value="12,5"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="MinWidth" Value="55"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
          <BrushTransition Property="Foreground" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="ToggleButton.filter-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#FFFFFF0C"/>
    </Style>
    <Style Selector="ToggleButton.filter-btn:checked /template/ ContentPresenter">
      <Setter Property="Background" Value="#FFFFFF10"/>
      <Setter Property="BorderBrush" Value="#FFFFFF15"/>
    </Style>
    <Style Selector="ToggleButton.filter-btn:checked">
      <Setter Property="Foreground" Value="#E0E0F0"/>
    </Style>
  </UserControl.Styles>

  <DockPanel>
    <!-- 上部ツールバー -->
    <Border DockPanel.Dock="Top" Background="#FFFFFF06" Padding="14,10"
            BorderBrush="#FFFFFF08" BorderThickness="0,0,0,1">
      <DockPanel>
        <!-- 右側: クリアボタン -->
        <Button DockPanel.Dock="Right" Content="Clear"
                Command="{Binding ClearCommand}"
                Background="#FFFFFF08" Foreground="#A0A0B5"
                BorderThickness="1" BorderBrush="#FFFFFF08"
                Padding="14,5" CornerRadius="8" FontSize="11"
                Cursor="Hand" Margin="10,0,0,0"/>

        <!-- フィルタートグル群 -->
        <StackPanel Orientation="Horizontal" Spacing="6" DockPanel.Dock="Left">
          <ToggleButton Classes="filter-btn" IsChecked="{Binding ShowDebug}">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="DBG" Foreground="#6CAEDD" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding DebugCount}" Foreground="#606075" FontSize="10"/>
            </StackPanel>
          </ToggleButton>
          <ToggleButton Classes="filter-btn" IsChecked="{Binding ShowInfo}">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="INF" Foreground="#B0B0C0" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding InfoCount}" Foreground="#606075" FontSize="10"/>
            </StackPanel>
          </ToggleButton>
          <ToggleButton Classes="filter-btn" IsChecked="{Binding ShowWarning}">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="WRN" Foreground="#E8C44A" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding WarningCount}" Foreground="#606075" FontSize="10"/>
            </StackPanel>
          </ToggleButton>
          <ToggleButton Classes="filter-btn" IsChecked="{Binding ShowError}">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="ERR" Foreground="#E05252" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding ErrorCount}" Foreground="#606075" FontSize="10"/>
            </StackPanel>
          </ToggleButton>

          <!-- 検索ボックス - モダン -->
          <TextBox Text="{Binding SearchText}"
                   Watermark="&#x1F50D; Search..."
                   Width="220" FontSize="12"
                   Background="#FFFFFF06" Foreground="#C0C0D0"
                   BorderBrush="#FFFFFF0C" BorderThickness="1"
                   CornerRadius="8" Padding="10,5"
                   Margin="12,0,0,0"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- 下部: スタックトレース詳細 -->
    <Border DockPanel.Dock="Bottom" Background="#FFFFFF04"
            BorderBrush="#FFFFFF08" BorderThickness="0,1,0,0"
            Height="150"
            IsVisible="{Binding SelectedEntry, Converter={StaticResource NotNullOrEmpty}}">
      <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FFFFFF06" Padding="14,7"
                BorderBrush="#FFFFFF08" BorderThickness="0,0,0,1">
          <TextBlock Text="Stack Trace" Foreground="#707085" FontSize="11" FontWeight="SemiBold"/>
        </Border>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
          <TextBlock Text="{Binding SelectedEntry.StackTrace}"
                     FontFamily="Consolas,Menlo,monospace"
                     FontSize="11" Foreground="#9090A5"
                     TextWrapping="Wrap"/>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- ログリスト -->
    <ListBox ItemsSource="{Binding DisplayEntries}"
             SelectedItem="{Binding SelectedEntry}"
             Background="Transparent"
             BorderThickness="0"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
      <ListBox.Styles>
        <Style Selector="ListBoxItem">
          <Setter Property="Padding" Value="0"/>
          <Setter Property="Margin" Value="0"/>
          <Setter Property="MinHeight" Value="0"/>
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="Foreground" Value="#C0C0D5"/>
        </Style>
        <Style Selector="ListBoxItem /template/ ContentPresenter">
          <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
          <Setter Property="Background" Value="#FFFFFF06"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
          <Setter Property="Background" Value="#FFFFFF0C"/>
        </Style>
        <Style Selector="ListBoxItem:selected:focus /template/ ContentPresenter">
          <Setter Property="Background" Value="#FFFFFF0C"/>
        </Style>
        <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
          <Setter Property="Background" Value="#FFFFFF10"/>
        </Style>
      </ListBox.Styles>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="log:LogEntry">
          <Border Padding="14,6" BorderBrush="#FFFFFF06" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="65,45,*">
              <TextBlock Grid.Column="0"
                         Text="{Binding Timestamp, Converter={StaticResource Timestamp}}"
                         Foreground="#505065" FontSize="11"
                         FontFamily="Consolas,Menlo,monospace"
                         VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1"
                         Text="{Binding Level, Converter={StaticResource LevelToStr}}"
                         Foreground="{Binding Level, Converter={StaticResource LevelToBrush}}"
                         FontSize="11" FontWeight="Bold"
                         FontFamily="Consolas,Menlo,monospace"
                         VerticalAlignment="Center"/>
              <TextBlock Grid.Column="2"
                         Text="{Binding Message}"
                         Foreground="#C0C0D5" FontSize="12"
                         TextTrimming="CharacterEllipsis"
                         VerticalAlignment="Center"
                         Margin="8,0,0,0"/>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</UserControl>
