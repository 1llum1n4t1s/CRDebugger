<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CRDebugger.Core.ViewModels"
             xmlns:log="using:CRDebugger.Core.Logging"
             xmlns:conv="using:CRDebugger.Avalonia.Converters"
             x:Class="CRDebugger.Avalonia.Views.ConsoleView"
             x:DataType="vm:ConsoleViewModel">

  <UserControl.Resources>
    <conv:LogLevelToBrushConverter x:Key="LevelToBrush"/>
    <conv:LogLevelToStringConverter x:Key="LevelToStr"/>
    <conv:TimestampConverter x:Key="Timestamp"/>
    <conv:NotNullOrEmptyConverter x:Key="NotNullOrEmpty"/>
    <conv:InverseBoolConverter x:Key="InverseBool"/>
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- フィルタートグルボタン -->
    <Style Selector="ToggleButton.filter-btn">
      <Setter Property="Background" Value="#353548"/>
      <Setter Property="Foreground" Value="#888888"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="MinWidth" Value="50"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="ToggleButton.filter-btn:checked /template/ ContentPresenter">
      <Setter Property="Background" Value="#404060"/>
    </Style>
    <Style Selector="ToggleButton.filter-btn:checked">
      <Setter Property="Foreground" Value="#E0E0E0"/>
    </Style>
  </UserControl.Styles>

  <DockPanel Margin="0">
    <!-- 上部ツールバー -->
    <Border DockPanel.Dock="Top" Background="#2A2A3C" Padding="12,8"
            BorderBrush="#404060" BorderThickness="0,0,0,1">
      <DockPanel>
        <!-- 右側: クリアボタン -->
        <Button DockPanel.Dock="Right" Content="Clear"
                Command="{Binding ClearCommand}"
                Background="#353548" Foreground="#CCCCCC"
                BorderThickness="0" Padding="12,4" CornerRadius="4" FontSize="11"
                Margin="8,0,0,0"/>

        <!-- フィルタートグル群 -->
        <StackPanel Orientation="Horizontal" Spacing="6" DockPanel.Dock="Left">
          <ToggleButton Classes="filter-btn" IsChecked="{Binding ShowDebug}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="DBG" Foreground="#6CAEDD"/>
              <TextBlock Text="{Binding DebugCount}" Foreground="#888888" FontSize="10"/>
            </StackPanel>
          </ToggleButton>
          <ToggleButton Classes="filter-btn" IsChecked="{Binding ShowInfo}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="INF" Foreground="#B0B0B0"/>
              <TextBlock Text="{Binding InfoCount}" Foreground="#888888" FontSize="10"/>
            </StackPanel>
          </ToggleButton>
          <ToggleButton Classes="filter-btn" IsChecked="{Binding ShowWarning}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="WRN" Foreground="#E8C44A"/>
              <TextBlock Text="{Binding WarningCount}" Foreground="#888888" FontSize="10"/>
            </StackPanel>
          </ToggleButton>
          <ToggleButton Classes="filter-btn" IsChecked="{Binding ShowError}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="ERR" Foreground="#E05252"/>
              <TextBlock Text="{Binding ErrorCount}" Foreground="#888888" FontSize="10"/>
            </StackPanel>
          </ToggleButton>

          <!-- 検索ボックス -->
          <TextBox Text="{Binding SearchText}"
                   Watermark="Search..."
                   Width="200" FontSize="12"
                   Background="#1E1E2E" Foreground="#CCCCCC"
                   BorderBrush="#404060" BorderThickness="1"
                   CornerRadius="4" Padding="8,4"
                   Margin="10,0,0,0"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- 下部: スタックトレース詳細 -->
    <Border DockPanel.Dock="Bottom" Background="#2A2A3C"
            BorderBrush="#404060" BorderThickness="0,1,0,0"
            Height="150"
            IsVisible="{Binding SelectedEntry, Converter={StaticResource NotNullOrEmpty}}">
      <DockPanel>
        <Border DockPanel.Dock="Top" Background="#353548" Padding="12,6"
                BorderBrush="#404060" BorderThickness="0,0,0,1">
          <TextBlock Text="Stack Trace" Foreground="#888888" FontSize="11" FontWeight="SemiBold"/>
        </Border>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8">
          <TextBlock Text="{Binding SelectedEntry.StackTrace}"
                     FontFamily="Consolas,Menlo,monospace"
                     FontSize="11" Foreground="#AAAAAA"
                     TextWrapping="Wrap"/>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- ログリスト -->
    <ListBox ItemsSource="{Binding DisplayEntries}"
             SelectedItem="{Binding SelectedEntry}"
             Background="#1E1E2E"
             BorderThickness="0"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
      <ListBox.Styles>
        <Style Selector="ListBoxItem">
          <Setter Property="Padding" Value="0"/>
          <Setter Property="Margin" Value="0"/>
          <Setter Property="MinHeight" Value="0"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
          <Setter Property="Background" Value="#353548"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
          <Setter Property="Background" Value="#2A2A3C"/>
        </Style>
      </ListBox.Styles>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="log:LogEntry">
          <Border Padding="12,4" BorderBrush="#2A2A3C" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="60,40,*">
              <!-- タイムスタンプ -->
              <TextBlock Grid.Column="0"
                         Text="{Binding Timestamp, Converter={StaticResource Timestamp}}"
                         Foreground="#666666" FontSize="11"
                         FontFamily="Consolas,Menlo,monospace"
                         VerticalAlignment="Center"/>
              <!-- レベルバッジ -->
              <TextBlock Grid.Column="1"
                         Text="{Binding Level, Converter={StaticResource LevelToStr}}"
                         Foreground="{Binding Level, Converter={StaticResource LevelToBrush}}"
                         FontSize="11" FontWeight="Bold"
                         FontFamily="Consolas,Menlo,monospace"
                         VerticalAlignment="Center"/>
              <!-- メッセージ -->
              <TextBlock Grid.Column="2"
                         Text="{Binding Message}"
                         Foreground="#CCCCCC" FontSize="12"
                         TextTrimming="CharacterEllipsis"
                         VerticalAlignment="Center"
                         Margin="8,0,0,0"/>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</UserControl>
